# 飞书应用凭据（示例）。
#
# 真实 .env 不进 git —— 由 felag-server 摄取本官方源时，从平台库
# plg_felagplugin_config(lark_app_id / lark_app_secret) 读值、注入生成
# .env 到分发包内(算 sha256 之前，纳入签名)。client 装包后读该 .env，
# 把 LARK_APP_ID/LARK_APP_SECRET 展开进 lark-mcp 子进程 env(APP_ID/APP_SECRET)。
#
# 凭据的唯一维护点在日报 plugins-sync.yaml 的 credentials 段(name=lark)。
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=your_app_secret_here
